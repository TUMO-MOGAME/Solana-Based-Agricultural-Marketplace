# Copy this to .env.local and fill in real values. .env.local is gitignored.
#
# All vars are OPTIONAL. If Supabase vars are missing, the auth pages and
# dashboard fall back to a demo mode that lets you browse the app without
# a backend. Real auth kicks in automatically once these are populated.

# --- Supabase (optional — enables real auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Solana RPC (optional — overrides the default devnet endpoint) ---
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
