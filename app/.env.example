# Copy this to .env.local and fill in real values. .env.local is gitignored.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (optional) ---
# Only needed if the CopilotKit chat (a2a-chat.tsx) is used.
OPENAI_API_KEY=

# --- Python agent backend (optional, NOT in Vuna scope) ---
# These are inherited from the Social Assembly source. Leaving them unset
# is fine — the affected API routes will return clean 503s. Listed here
# only so future-you knows what the route handlers are looking for.
# COACHING_PORT=
# COACHING_URL=
# PROFILER_URL=
# ANALYST_URL=
# STRATEGIST_URL=
# RESEARCHER_URL=
# CREATOR_URL=
# LEARNER_URL=
# PANEL_STRATEGIC_URL=
# PANEL_QUALITY_URL=
# PANEL_SAFETY_URL=
# PANEL_BRAND_URL=
# PANEL_PLATFORM_URL=
