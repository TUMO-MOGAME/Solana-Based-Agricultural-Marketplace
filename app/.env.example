# Copy this to .env.local and fill in real values. .env.local is gitignored.
#
# All vars are OPTIONAL. If Supabase vars are missing, the auth pages and
# dashboard fall back to a demo mode that lets you browse the app without
# a backend. Real auth kicks in automatically once these are populated.

# --- Supabase (optional — enables real auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Solana RPC (optional — overrides the default devnet endpoint) ---
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# --- Privy embedded wallet (optional — enables custodial farmer wallets) ---
# When set, the dashboard switches its wallet path from Phantom (browser
# extension popup, seed phrase) to Privy (email login → auto-created
# embedded Solana wallet → no seed phrase, hides the chain from farmers).
# Get an app ID free at https://privy.io → Create app. Cluster defaults
# to devnet via NEXT_PUBLIC_SOLANA_CLUSTER below.
# NEXT_PUBLIC_PRIVY_APP_ID=
# NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# --- ElevenLabs TTS (optional — enables voice playback in the dashboard) ---
# Server-side only. NEVER prefix with NEXT_PUBLIC_ — the key must not ship to
# the browser. The /api/tts route reads this and proxies the audio.
ELEVENLABS_API_KEY=
# Default voice to use for TTS. The example below is a multilingual voice.
# Pick any voice ID from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=NOpBlnGInO9m6vDvFkFC
